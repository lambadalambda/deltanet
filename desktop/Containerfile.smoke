FROM --platform=linux/amd64 docker.io/library/node@sha256:4e9cb555d708e0829c9d93e5eeae9dfab0617b832ca436a690680e0fca735ef5

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        dbus-x11 \
        libasound2 \
        libatk-bridge2.0-0 \
        libatk1.0-0 \
        libatspi2.0-0 \
        libcups2 \
        libdrm2 \
        libgbm1 \
        libgtk-3-0 \
        libnss3 \
        libx11-xcb1 \
        libxcb-dri3-0 \
        libxcomposite1 \
        libxdamage1 \
        libxkbcommon0 \
        libxrandr2 \
        libxss1 \
        xauth \
        xvfb \
    && rm -rf /var/lib/apt/lists/* \
    && corepack enable \
    && corepack prepare pnpm@11.5.2 --activate

WORKDIR /workspace
COPY --chown=node:node . .
USER node

RUN pnpm --dir daemon install --frozen-lockfile \
    && pnpm --dir frontend install --frozen-lockfile \
    && electron_config_cache=desktop/.cache/electron pnpm --dir desktop install --frozen-lockfile

CMD ["dbus-run-session", "--", "xvfb-run", "-a", "pnpm", "--dir", "desktop", "test:smoke"]
